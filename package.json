{
  "name": "@wopr-network/radar",
  "version": "1.7.3",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "bin": {
    "radar": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "extends": "@wopr-network/semantic-release-config"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wopr-network/radar.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "check": "tsc -p tsconfig.json --noEmit && biome check src",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "vitest run",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@wopr-network/defcon": "^0.2.2",
    "better-sqlite3": "^12.6.2",
    "commander": "^13.0.0",
    "dockerode": "^4.0.9",
    "drizzle-orm": "^0.45.1",
    "handlebars": "^4.7.8",
    "mcp-remote": "^0.1.18",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  }
}
