{
  "name": "@wopr-network/norad",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "bin": {
    "norad": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && biome check src",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "vitest run",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "commander": "^13.0.0",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.3.6"
  }
}
