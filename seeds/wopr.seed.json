{
  "flows": [
    {
      "name": "engineering",
      "description": "WOPR engineering flow — 8 states, 9 transitions, Handlebars prompt templates.",
      "initialState": "backlog",
      "maxConcurrent": 4,
      "maxConcurrentPerRepo": 2,
      "states": [
        {
          "name": "backlog",
          "mode": "passive"
        },
        {
          "name": "architecting",
          "agentRole": "architect",
          "modelTier": "opus",
          "mode": "active",
          "promptTemplate": "You are an architect. Analyze issue {{issueKey}} and write a detailed implementation spec. Post the spec as a comment on the Linear issue. If the issue requires UI design work, signal design_needed. Otherwise, signal spec_ready."
        },
        {
          "name": "ui_designing",
          "agentRole": "designer",
          "modelTier": "opus",
          "mode": "active",
          "promptTemplate": "You are a UI designer. Create design specs for issue {{issueKey}} based on the architect's spec. Post the design as a comment on the Linear issue, then signal design_ready."
        },
        {
          "name": "coding",
          "agentRole": "coder",
          "modelTier": "sonnet",
          "mode": "active",
          "promptTemplate": "You are a coder. Implement issue {{issueKey}} following the spec. Create a PR, then signal pr_created."
        },
        {
          "name": "reviewing",
          "agentRole": "reviewer",
          "modelTier": "sonnet",
          "mode": "active",
          "promptTemplate": "You are a reviewer. Review the PR for issue {{issueKey}}. If clean, signal clean. If issues found, signal issues."
        },
        {
          "name": "fixing",
          "agentRole": "fixer",
          "modelTier": "sonnet",
          "mode": "active",
          "promptTemplate": "You are a fixer. Address review comments on the PR for issue {{issueKey}}. Push fixes, then signal fixes_pushed. If unresolvable, signal cant_resolve."
        },
        {
          "name": "done",
          "mode": "passive"
        },
        {
          "name": "stuck",
          "mode": "passive"
        }
      ],
      "transitions": [
        {
          "fromState": "backlog",
          "toState": "architecting",
          "trigger": "start",
          "condition": "unblocked_gate AND pr_capacity_gate"
        },
        {
          "fromState": "architecting",
          "toState": "coding",
          "trigger": "spec_ready",
          "condition": "spec_posted_gate"
        },
        {
          "fromState": "architecting",
          "toState": "ui_designing",
          "trigger": "design_needed",
          "condition": "spec_posted_gate"
        },
        {
          "fromState": "ui_designing",
          "toState": "coding",
          "trigger": "design_ready",
          "condition": "design_posted_gate"
        },
        {
          "fromState": "coding",
          "toState": "reviewing",
          "trigger": "pr_created",
          "condition": "review_ready_gate"
        },
        {
          "fromState": "reviewing",
          "toState": "done",
          "trigger": "clean",
          "condition": "merge_gate"
        },
        {
          "fromState": "reviewing",
          "toState": "fixing",
          "trigger": "issues"
        },
        {
          "fromState": "fixing",
          "toState": "reviewing",
          "trigger": "fixes_pushed",
          "condition": "review_ready_gate"
        },
        {
          "fromState": "fixing",
          "toState": "stuck",
          "trigger": "cant_resolve"
        }
      ]
    }
  ],
  "sources": [
    {
      "id": "linear-wopr",
      "type": "linear",
      "token": "${LINEAR_API_KEY}",
      "config": {
        "teamKey": "WOP"
      }
    }
  ],
  "watches": [
    {
      "id": "watch-linear-defcon",
      "sourceId": "linear-wopr",
      "event": "issue.state_change",
      "flowName": "engineering",
      "filter": { "state": "Todo", "labels": ["defcon"] }
    },
    {
      "id": "watch-linear-norad",
      "sourceId": "linear-wopr",
      "event": "issue.state_change",
      "flowName": "engineering",
      "filter": { "state": "Todo", "labels": ["norad"] }
    },
    {
      "id": "watch-linear-wopr-platform",
      "sourceId": "linear-wopr",
      "event": "issue.state_change",
      "flowName": "engineering",
      "filter": { "state": "Todo", "labels": ["wopr-platform"] }
    },
    {
      "id": "watch-linear-wopr-platform-ui",
      "sourceId": "linear-wopr",
      "event": "issue.state_change",
      "flowName": "engineering",
      "filter": { "state": "Todo", "labels": ["wopr-platform-ui"] }
    },
    {
      "id": "watch-linear-plugin-discord",
      "sourceId": "linear-wopr",
      "event": "issue.state_change",
      "flowName": "engineering",
      "filter": { "state": "Todo", "labels": ["plugin-discord"] }
    },
    {
      "id": "watch-linear-plugin-msteams",
      "sourceId": "linear-wopr",
      "event": "issue.state_change",
      "flowName": "engineering",
      "filter": { "state": "Todo", "labels": ["plugin-msteams"] }
    },
    {
      "id": "watch-linear-plugin-whatsapp",
      "sourceId": "linear-wopr",
      "event": "issue.state_change",
      "flowName": "engineering",
      "filter": { "state": "Todo", "labels": ["plugin-whatsapp"] }
    },
    {
      "id": "watch-linear-security",
      "sourceId": "linear-wopr",
      "event": "issue.state_change",
      "flowName": "engineering",
      "filter": { "state": "Todo", "labels": ["security"] }
    }
  ]
}
